---
/**
 * About page — /about
 *
 * An evergreen authority page built for search engines and AI assistants. The
 * "Nusa Lembongan" keyword is front-loaded (≈5× the search volume of "Nusa
 * Ceningan") while the resort's true location is kept accurate — positioned as
 * "the island connected to Nusa Lembongan." Ranks for both terms honestly.
 *
 * Mirrors the "Coastal Calm" design system and the section rhythm of the
 * retreat page. Content lives in @data/site.ts (aboutHighlights,
 * aboutQuickFacts, aboutFaqs). Ships LodgingBusiness + BreadcrumbList +
 * FAQPage JSON-LD for rich results and reliable AI-entity parsing.
 */
import Base from '@layouts/Base.astro';
import {
  site,
  contact,
  reviews,
  cta,
  aboutHighlights,
  aboutQuickFacts,
  aboutFaqs,
} from '@data/site';

// Real coordinates (shared with the contact + location pages).
const latitude = -8.6968955;
const longitude = 115.4498182;

// Structured data — LodgingBusiness (entity for AI/Google) + BreadcrumbList +
// FAQPage. Built from real site/contact data: no placeholders.
const lodgingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  '@id': `${site.url}/about#resort`,
  name: site.name,
  description:
    'Oceanfront boutique resort on Nusa Ceningan, the island connected to Nusa Lembongan, Bali. Features an infinity pool, sauna, restaurant, and pool bar. Open to day guests via minimum spend.',
  url: `${site.url}/about`,
  image: `${site.url}/images/general/aerial-infinity-pool.jpg`,
  priceRange: '$$',
  starRating: { '@type': 'Rating', ratingValue: '4' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.addressLine1,
    addressLocality: 'Nusa Ceningan',
    addressRegion: 'Bali',
    addressCountry: 'ID',
  },
  geo: { '@type': 'GeoCoordinates', latitude, longitude },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: reviews.googleRating,
    reviewCount: reviews.googleCount,
  },
  areaServed: ['Nusa Lembongan', 'Nusa Ceningan', 'Nusa Penida'],
  containsPlace: {
    '@type': 'Place',
    name: 'Nusa Ceningan (connected to Nusa Lembongan via the Yellow Bridge)',
  },
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Oceanfront location', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Infinity pool', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Sauna', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Restaurant', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Pool bar', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Day guests welcome', value: true },
  ],
  availableLanguage: ['English', 'Indonesian'],
  sameAs: [contact.instagramUrl, contact.facebook, contact.tiktok],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${site.url}/about` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: aboutFaqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Base
  title="Segara Seaside Resort | Oceanfront Boutique Stay, Nusa Lembongan, Bali"
  description="Segara Seaside Resort is an oceanfront boutique resort near Nusa Lembongan, Bali — on Nusa Ceningan, just across the bridge. Infinity pool, sauna, poolside dining. Day guests welcome."
  image="/images/general/aerial-infinity-pool.jpg"
  schema={[lodgingSchema, breadcrumbSchema, faqSchema]}
>
  {/* ─── HERO ─── */}
  <section class="relative flex min-h-[100svh] items-center overflow-hidden bg-lagoon-700">
    <img
      src="/images/general/aerial-infinity-pool.jpg"
      alt="Aerial view of Segara Seaside Resort's oceanfront infinity pool on Nusa Ceningan, near Nusa Lembongan"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      aria-hidden="true"
    />

    {/* Legibility gradient (top + bottom) */}
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-lagoon-700/40 via-transparent to-lagoon-700/70"></div>

    <div class="container-bleed relative z-10 flex min-h-[100svh] flex-col justify-between pt-28 pb-20 md:pb-28">
      {/* Eyebrow — sits right under the menu */}
      <p class="overline text-white/90">Boutique Oceanfront Stay · Nusa Lembongan, Bali</p>

      {/* Heading + buttons — bottom of the hero, lots of breathing room */}
      <div class="max-w-2xl text-white">
        <h1 class="text-[clamp(2.5rem,6vw,4.75rem)] leading-[1.02] text-white">
          Boutique Oceanfront Living<br /> Near Nusa Lembongan, Bali
        </h1>
        <div class="mt-9 flex flex-wrap gap-4">
          <a href="/rooms" class="btn-primary text-base">{cta.label} ▸</a>
          <a href="#overview" class="btn-secondary border-white/70 text-white hover:bg-white/10">
            Explore Segara ▸
          </a>
        </div>
      </div>
    </div>

    {/* Scroll cue */}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/70" aria-hidden="true">
      <svg width="22" height="34" viewBox="0 0 22 34" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="1" width="20" height="32" rx="10" />
        <line x1="11" y1="8" x2="11" y2="14" class="animate-bounce" />
      </svg>
    </div>
  </section>

  {/* ─── OVERVIEW / INTRO ─── */}
  <section id="overview" class="section bg-paper">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="overline">About Segara Seaside Resort</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">
            Oceanfront Boutique Living Near Nusa Lembongan
          </h2>
          <div class="mt-6 max-w-prose space-y-4 text-lg leading-relaxed text-ink/90">
            <p>
              Segara Seaside Resort combines tropical island charm with modern boutique comfort on
              the quiet coast of <strong>Nusa Ceningan</strong>, the island connected to
              <strong>Nusa Lembongan</strong> by the famous Yellow Bridge. Set directly on the
              ocean, the resort brings together exclusive accommodation, wellness, and relaxed
              dining in one of Bali's most unspoiled island destinations — just minutes from Nusa
              Lembongan's beaches and a short trip from Nusa Penida.
            </p>
            <p>
              It's the best of both worlds: the calm, authentic atmosphere of Nusa Ceningan, with
              everything Nusa Lembongan is loved for only a short crossing away.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/rooms" class="btn-primary">{cta.label} ▸</a>
            <a href="/location" class="btn-secondary">See the Location</a>
          </div>
        </div>

        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
          <img
            src="/images/general/aerial-infinity-pool.jpg"
            alt="Segara Seaside Resort's infinity pool overlooking the ocean, Nusa Ceningan near Nusa Lembongan"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ─── AWAY FROM THE CROWDS ─── */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="order-2 aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200 lg:order-1">
          <img
            src="/images/general/bungalows-exterior.jpg"
            alt="Stylish oceanfront bungalows at Segara Seaside Resort near Nusa Lembongan"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="order-1 lg:order-2">
          <p class="overline">Privacy, Comfort &amp; Calm</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">
            An Oceanfront Boutique Resort Away from the Crowds
          </h2>
          <p class="mt-6 max-w-prose leading-relaxed text-ink/90">
            Designed for travelers who want to experience Bali beyond the busy tourist hubs, Segara
            offers stylish <strong>bungalows and villas</strong> that prioritize privacy, comfort,
            and calm. Its Nusa Lembongan-area location is ideal for guests seeking
            <strong>peace, nature, ocean views, and an authentic island atmosphere</strong> —
            without sacrificing modern comfort.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/rooms" class="btn-secondary">View Accommodation ▸</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── INFINITY POOL, SAUNA & WELLNESS ─── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="overline">Wellness by the Ocean</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Infinity Pool, Sauna &amp; Wellness</h2>
          <p class="mt-6 max-w-prose leading-relaxed text-ink/90">
            The <strong>infinity pool with ocean view</strong> is the resort's centerpiece — perfect
            for swimming, sunbathing, and taking in the tropical surroundings. The
            <strong>sauna</strong> is a rare wellness highlight among Nusa Lembongan resorts,
            available to both hotel guests and outside visitors, and positions Segara as a small
            <strong>wellness destination</strong> in the islands.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/wellness" class="btn-secondary">Explore Wellness ▸</a>
          </div>
        </div>

        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
          <img
            src="/images/general/ocean-view-sauna.jpg"
            alt="Ocean-view Finnish cedar sauna at Segara Seaside Resort, a rare wellness highlight near Nusa Lembongan"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ─── DINING ─── */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="order-2 aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200 lg:order-1">
          <img
            src="/images/dining/oceanfront-restaurant.jpg"
            alt="Oceanfront restaurant and pool bar at Segara Seaside Resort, near Nusa Lembongan"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="order-1 lg:order-2">
          <p class="overline">Pool &amp; Ocean</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Relaxed Dining by the Pool and Ocean</h2>
          <p class="mt-6 max-w-prose leading-relaxed text-ink/90">
            Segara's culinary concept is relaxed yet refined. The <strong>restaurant and pool
            bar</strong> serve popular dishes, light bites, snacks, and refreshing drinks — ideal
            for a full day by the pool, the ocean, or a peaceful sunset over the Indian Ocean.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ─── DAY GUESTS ─── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">No Overnight Stay Needed</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">
          Open to Day Guests from Nusa Lembongan, Ceningan &amp; Penida
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink/90">
          Day guests from <strong>Nusa Lembongan, Nusa Ceningan, and Nusa Penida</strong> are
          welcome. Outside visitors can enjoy the <strong>pool, sauna, and restaurant</strong>
          through a minimum spend, making the Segara experience accessible without an overnight stay.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href={contact.whatsappLink} class="btn-primary" target="_blank" rel="noopener">
            Ask About Day Access ▸
          </a>
          <a href="/wellness" class="btn-secondary">See the Facilities</a>
        </div>
      </div>
    </div>
  </section>

  {/* ─── KEY HIGHLIGHTS ─── */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Key Highlights</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">What Makes Segara Special</h2>
        <p class="mt-4 text-slate">
          Everything that defines an oceanfront boutique stay near Nusa Lembongan — in one place.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {aboutHighlights.map((h) => (
          <div class="card p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-seafoam-100 text-lagoon-600">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 16c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2 2-2 4-2M2 20c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2 2-2 4-2M5 12l2-6h10l2 6" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg leading-snug">{h.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate">{h.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── QUICK FACTS ─── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">At a Glance</p>
        <h2 class="mt-3 text-[clamp(1.75rem,3vw,2.5rem)]">Quick Facts</h2>
        <p class="mt-4 text-slate">
          The essentials about Segara Seaside Resort — location, setting, facilities, and access.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-3xl overflow-hidden rounded-lg border border-line bg-paper">
        <table class="w-full text-left text-sm">
          <tbody class="divide-y divide-line">
            {aboutQuickFacts.map((f) => (
              <tr class="align-top">
                <th scope="row" class="w-1/3 bg-mist/60 px-5 py-4 font-medium text-ink">
                  {f.attribute}
                </th>
                <td class="px-5 py-4 leading-relaxed text-slate">{f.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* ─── FAQ ─── */}
  <section id="faq" class="section bg-mist">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Good to Know</p>
        <h2 class="mt-3 text-[clamp(1.75rem,3vw,2.5rem)]">Frequently Asked Questions</h2>
        <p class="mt-4 text-slate">
          Quick answers about where Segara is, what it offers, and how to visit — for guests and
          day visitors to the Nusa Lembongan area.
        </p>
      </div>
      <div class="mx-auto mt-12 max-w-3xl divide-y divide-line">
        {aboutFaqs.map((item, i) => (
          <details class="group py-5" name="about-faq" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-serif text-lg text-ink marker:hidden [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <span class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full border border-line text-lagoon-600 transition-transform duration-300 group-open:rotate-45" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="7" y1="1" x2="7" y2="13" /><line x1="1" y1="7" x2="13" y2="7" /></svg>
              </span>
            </summary>
            <p class="mt-4 max-w-prose leading-relaxed text-slate">{item.answer}</p>
          </details>
        ))}
      </div>

      <div class="mx-auto mt-12 max-w-2xl text-center">
        <p class="text-sm text-slate">Still have a question?</p>
        <a href="/contact" class="btn-ghost mt-2">Get in touch ▸</a>
      </div>
    </div>
  </section>

  {/* ─── FINAL CTA ─── */}
  <section class="relative overflow-hidden bg-lagoon-700">
    <div class="container-content relative z-10 py-20 text-center md:py-28">
      <p class="overline text-white/80">Stay with Segara</p>
      <h2 class="mx-auto mt-3 max-w-3xl text-[clamp(2rem,4vw,3.25rem)] leading-tight text-white">
        Experience Boutique Oceanfront Living Near Nusa Lembongan
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-white/90">
        Stylish bungalows and villas, an infinity pool, a sauna, and relaxed oceanfront dining —
        on the quiet island connected to Nusa Lembongan. Book direct for the best experience.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/rooms" class="btn-primary text-base">{cta.label} ▸</a>
        <a href={contact.whatsappLink} class="btn-secondary border-white/70 text-white hover:bg-white/10" target="_blank" rel="noopener">
          Message Us on WhatsApp ▸
        </a>
      </div>
    </div>
  </section>
</Base>

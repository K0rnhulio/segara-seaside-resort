---
/**
 * Homepage — 9 sections per docs/05-wireframes.md.
 * Coastal Calm design system applied throughout.
 */
import Base from '@layouts/Base.astro';
import FAQ from '@components/FAQ.astro';
import { resortSchema } from '@data/resort-schema';
import {
  site,
  rooms,
  valueProps,
  experiences,
  reviews,
  instagramTiles,
  contact,
  wellnessHighlights,
  locationPoints,
  cta,
  faqs,
} from '@data/site';

// JSON-LD: Hotel schema for SEO (docs/01 §5.8)
const hotelSchema = {
  '@context': 'https://schema.org',
  '@type': 'Hotel',
  name: site.name,
  description: site.description,
  url: site.url,
  image: `${site.url}/og-default.svg`,
  priceRange: '$$$',
  starRating: { '@type': 'Rating', ratingValue: '3' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.addressLine1,
    addressLocality: 'Nusa Ceningan',
    addressRegion: 'Bali',
    addressCountry: 'ID',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: reviews.googleRating,
    reviewCount: reviews.googleCount,
  },
  amenityFeature: valueProps.map((v) => ({
    '@type': 'LocationFeatureSpecification',
    name: v.title,
  })),
};

// JSON-LD: FAQPage schema — eligible for rich results in Google (docs/01 §5.8)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base
  title="Segara Seaside Resort | Boutique Stay Near Nusa Lembongan"
  description="Oceanfront boutique resort on Nusa Ceningan. Infinity pool, sauna, cold plunge, pet-friendly stays. Steps from Song Tepo Beach. Book direct & save."
  schema={[hotelSchema, resortSchema, faqSchema]}
>
  {/* ───────────────────────── SECTION 1 — HERO (video) ───────────────────────── */}
  <section class="relative flex min-h-[100svh] items-center overflow-hidden">
    {/* Background video — muted, autoplay, loops. Poster = static fallback.
        prefers-reduced-motion handled via CSS below (hide video, show poster). */}
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/images/general/resort-aerial.jpg"
      data-hero-video
      aria-hidden="true"
    >
      <source src="/video/hero.mp4" type="video/mp4" />
      {/* Fallback text if video can't load */}
      Your browser does not support videos.
    </video>

    {/* Legibility gradient (top + bottom) */}
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-lagoon-700/40 via-transparent to-lagoon-700/60"></div>

    <div class="container-bleed relative z-10 py-32">
      <div class="max-w-2xl">
        <p class="overline text-white/90">Oceanfront Boutique Resort · Nusa Ceningan</p>
        <h1 class="mt-4 text-white text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05]">
          Oceanfront Boutique Resort Near Nusa Lembongan
        </h1>
        <p class="mt-6 max-w-xl text-lg text-white/90">
          Peaceful luxury on Nusa Ceningan, just minutes across the Yellow Bridge.
          Infinity pool, wellness facilities, and pet-friendly stays steps from Song Tepo Beach.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a href={cta.href} class="btn-primary text-base">{cta.label} ▸</a>
          <a href="/rooms" class="btn-secondary border-white/70 text-white hover:bg-white/10">
            Explore Our Stays
          </a>
        </div>
      </div>
    </div>

    {/* Scroll cue */}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/70" aria-hidden="true">
      <svg width="22" height="34" viewBox="0 0 22 34" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="1" width="20" height="32" rx="10" />
        <line x1="11" y1="8" x2="11" y2="14" class="animate-bounce" />
      </svg>
    </div>
  </section>

  {/* ───────────────────────── SECTION 2 — WHY SEGARA (4 USPs) ───────────────────────── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Why Segara</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">A More Peaceful Stay Near Nusa Lembongan</h2>
        <p class="mt-4 text-slate">
          Segara Seaside Resort offers an intimate oceanfront escape on Nusa Ceningan — the perfect
          balance between tranquility and convenience. Many guests looking for boutique resorts in
          Nusa Lembongan choose to stay with us because we are just a short ride across the iconic
          Yellow Bridge.
        </p>
      </div>
      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          valueProps.map((v) => (
            <div class="card p-8 text-center">
              <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-seafoam-100 text-lagoon-600">
                {v.icon === 'pool' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M2 16c2 0 2-1.5 4-1.5s2 1.5 4 1.5 2-1.5 4-1.5 2 1.5 4 1.5 2-1.5 4-1.5" />
                    <path d="M2 20c2 0 2-1.5 4-1.5s2 1.5 4 1.5 2-1.5 4-1.5 2 1.5 4 1.5 2-1.5 4-1.5" />
                    <path d="M7 13V6a2 2 0 0 1 4 0M17 13V6a2 2 0 0 0-4 0" />
                  </svg>
                )}
                {v.icon === 'pet' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="6" cy="8" r="2" /><circle cx="10" cy="5" r="2" />
                    <circle cx="14" cy="5" r="2" /><circle cx="18" cy="8" r="2" />
                    <path d="M8 14c0-3 2-5 4-5s4 2 4 5c0 3-2 6-4 6s-4-3-4-6z" />
                  </svg>
                )}
                {v.icon === 'wellness' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 3c2 3 5 5 5 9a5 5 0 0 1-10 0c0-4 3-6 5-9z" />
                    <path d="M9 13c0 1.5 1.5 2.5 3 2.5" />
                  </svg>
                )}
                {v.icon === 'intimate' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 21s-8-5-8-11a4 4 0 0 1 8-1 4 4 0 0 1 8 1c0 6-8 11-8 11z" />
                  </svg>
                )}
              </div>
              <h3 class="mt-5 text-lg">{v.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 3 — ACCOMMODATION ───────────────────────── */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="max-w-2xl">
        <p class="overline">Accommodation</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Thoughtfully Designed Stays Near Nusa Lembongan</h2>
        <p class="mt-4 text-slate">
          Choose from elegant Deluxe Bungalows or our spacious Two-Bedroom Villa with Private Pool.
          All accommodations are designed for comfort and feature modern amenities in a serene island setting.
        </p>
      </div>

      <div class="mt-16 space-y-20">
        {
          rooms.map((room, i) => (
            <div class:list={['grid items-center gap-10 lg:grid-cols-2', i % 2 === 1 && 'lg:[direction:rtl]']}>
              <div class="[direction:ltr]">
                <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
                  <img
                    src={room.image}
                    alt={`${room.name} at ${site.name}`}
                    class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="[direction:ltr]">
                <p class="overline">{room.overline}</p>
                <h3 class="mt-3 text-3xl">{room.name}</h3>
                <p class="mt-5 max-w-prose text-slate">{room.shortDescription}</p>
                <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate">
                  {room.features.map((f) => (
                    <li class="flex items-center gap-1.5">
                      <span class="text-lagoon-600">✓</span> {f}
                    </li>
                  ))}
                </ul>
                <p class="mt-6 text-sm text-slate">
                  From <span class="font-medium text-brass-600 text-base">{room.priceFromLabel}</span> / night
                </p>
                <a href={room.href} class="btn-secondary mt-6">View Room ▸</a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 3.5 — WELLNESS ───────────────────────── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="overline">Wellness</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Wellness by the Ocean</h2>
          <p class="mt-5 max-w-prose text-slate">
            Our guests love starting the day with a swim in the infinity pool or ocean, followed by
            time in the sauna and cold plunge. The wellness area at Segara offers a peaceful reset,
            whether you’re staying for a romantic getaway or a relaxing break near Nusa Lembongan.
          </p>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {
              wellnessHighlights.map((w) => (
                <li class="rounded-lg border border-line bg-mist p-4">
                  <p class="font-serif text-base text-ink">{w.title}</p>
                  <p class="mt-1 text-sm text-slate">{w.body}</p>
                </li>
              ))
            }
          </ul>
          <a href="/wellness" class="btn-secondary mt-8">Discover Our Wellness Facilities ▸</a>
        </div>
        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
          <img
            src="/images/general/pool-bar.jpg"
            alt="Infinity pool overlooking the ocean at Segara Seaside Resort"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 4 — DINING (parallax banner) ───────────────────────── */}
  <section class="relative overflow-hidden">
    <div
      class="bg-cover bg-fixed bg-center py-32 md:py-44"
      style="background-image: linear-gradient(rgba(15,61,71,0.55), rgba(15,61,71,0.65)), url('/images/dining/restaurant.jpg');"
    >
      <div class="container-content text-center text-white">
        <p class="overline text-white/80">Oceanfront Dining</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Segara Steak House</h2>
        <p class="mx-auto mt-5 max-w-xl text-white/85">
          Savour sunset dinners & fresh island flavours with breathtaking views of the sea.
        </p>
        <a href={contact.whatsappLink} class="btn-primary mt-8" target="_blank" rel="noopener">Ask About Dining ▸</a>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 5 — EXPERIENCES ───────────────────────── */}
  <section class="section bg-seafoam-100">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Experiences</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Make the Island Yours</h2>
      </div>
      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {
          experiences.map((exp) => (
            <a href={contact.whatsappLink} target="_blank" rel="noopener" class="card group">
              <div class="aspect-[4/3] overflow-hidden bg-seafoam-200">
                <img
                  src={exp.image}
                  alt={exp.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg">{exp.title}</h3>
                <p class="mt-2 text-sm text-slate">{exp.body}</p>
              </div>
            </a>
          ))
        }
      </div>
      <div class="mt-12 text-center">
        <a href={contact.whatsappLink} class="btn-ghost" target="_blank" rel="noopener">Ask About Activities ▸</a>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 6 — LOCATION ───────────────────────── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="overline">The Location</p>
          <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">Conveniently Located Near Nusa Lembongan</h2>
          <p class="mt-5 max-w-prose text-slate">
            Segara Seaside Resort sits on peaceful Nusa Ceningan, connected to Nusa Lembongan by the
            famous Yellow Bridge. Many travelers searching for resorts in Nusa Lembongan stay with us
            for the quieter atmosphere while still enjoying easy access to Nusa Lembongan’s
            restaurants, beaches, and activities.
          </p>
          <ul class="mt-6 space-y-2 text-sm text-slate">
            {
              locationPoints.map((point) => (
                <li class="flex items-center gap-2">
                  <span class="text-lagoon-600">▢</span> {point}
                </li>
              ))
            }
          </ul>
          <a href="/location" class="btn-secondary mt-8">Learn More About Our Location ▸</a>
        </div>
        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
          <iframe
            title="Segara Seaside Resort location map — Song Tepo Beach, Nusa Ceningan"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7774.909644143069!2d115.44981820000001!3d-8.6968955!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd26da731527811%3A0x639e2fe202921059!2sSegara%20Seaside%20Resort!5e1!3m2!1sde!2s!4v1781894673297!5m2!1sde!2s"
            class="h-full w-full"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 7 — SOCIAL PROOF ───────────────────────── */}
  <section class="section bg-lagoon-700 text-white">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline text-white/70">Guest Stories</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)] text-white">What Our Guests Say</h2>
      </div>
      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {
          reviews.items.map((r) => (
            <figure class="rounded-lg border border-white/15 p-8">
              <div class="text-brass-500" aria-label="5 out of 5 stars">★★★★★</div>
              <blockquote class="mt-4 text-white/90">“{r.quote}”</blockquote>
              <figcaption class="mt-4 text-sm text-white/60">{r.author}</figcaption>
            </figure>
          ))
        }
      </div>
      <div class="mt-12 flex flex-col items-center justify-center gap-4 text-center text-white/80 sm:flex-row sm:gap-8">
        <p>★ {reviews.googleRating} / 5 · {reviews.googleCount} reviews (Google)</p>
        <span class="hidden sm:inline opacity-40">|</span>
        <p>★ {reviews.bookingRating} / 10 (Booking.com)</p>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 8 — INSTAGRAM FEED ───────────────────────── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Follow the Journey</p>
        <h2 class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">{contact.instagram}</h2>
      </div>
      <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {
          instagramTiles.map((tile) => (
            <a
              href={tile.url}
              target="_blank"
              rel="noopener"
              class="group relative aspect-square overflow-hidden rounded-lg bg-seafoam-200"
              aria-label="View on Instagram"
            >
              <img
                src={tile.image}
                alt="Instagram post"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center bg-lagoon-700/0 opacity-0 transition-all duration-300 group-hover:bg-lagoon-700/40 group-hover:opacity-100">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" fill="white" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href={contact.instagramUrl} class="btn-secondary" target="_blank" rel="noopener">
          Follow {contact.instagram} ▸
        </a>
      </div>
    </div>
  </section>

  {/* ───────────────────────── SECTION 8.5 — FAQ (SEO) ───────────────────────── */}
  <FAQ />

  {/* ───────────────────────── SECTION 9 — FINAL CTA ───────────────────────── */}
  <section class="relative overflow-hidden">
    <div
      class="bg-cover bg-center py-28 md:py-40"
      style="background-image: linear-gradient(rgba(15,61,71,0.6), rgba(15,61,71,0.6)), url('/images/cta-banner.svg');"
    >
      <div class="container-content text-center text-white">
        <h2 class="text-[clamp(2rem,4vw,3.25rem)] text-white">Ready to Experience Segara?</h2>
        <p class="mx-auto mt-5 max-w-xl text-white/85">
          Book directly with us for the best rates, more flexibility, and personal service. We
          personally welcome every guest — including your four-legged family members.
        </p>
        <a href={cta.href} class="btn-primary mt-8 text-base">Book Your Stay Directly ▸</a>
        <p class="mt-4 text-sm text-white/70">
          Or <a href={contact.whatsappLink} class="underline hover:text-white" target="_blank" rel="noopener">contact us via WhatsApp</a> for personalized assistance.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Reduced motion: hide hero video, rely on poster image instead */
  @media (prefers-reduced-motion: reduce) {
    [data-hero-video] {
      display: none;
    }
  }
  /* Mobile: disable parallax bg-fixed (janky on touch) */
  @media (hover: none) {
    [data-parallax] {
      background-attachment: scroll;
    }
  }
</style>

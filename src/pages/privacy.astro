---
/**
 * Privacy Policy page — /privacy
 * Linked from the footer on every page.
 * Covers data collection via the contact form, cookies, and third-party embeds.
 */
import Base from '@layouts/Base.astro';
import { site, contact } from '@data/site';

const lastUpdated = '26 June 2026';
---
<Base
  title="Privacy Policy"
  description="How Segara Seaside Resort collects, uses, and protects your personal data when you visit our website or contact us."
  noindex={false}
>
  <section class="bg-lagoon-700 py-16 text-white md:py-20">
    <div class="container-content text-center">
      <p class="overline text-white/70">Legal</p>
      <h1 class="mt-3 text-[clamp(2rem,4vw,3rem)] text-white">Privacy Policy</h1>
      <p class="mt-3 text-sm text-white/70">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <section class="section bg-paper">
    <div class="container-content max-w-3xl">
      <div class="prose-legal">
        <p class="lead">
          {site.name} ("we", "us", "our") respects your privacy and is committed to
          protecting your personal data. This policy explains what data we collect, why we
          collect it, and the choices you have. It applies to our website at
          <a href={site.url}>{site.url}</a>.
        </p>

        <h2>1. Data We Collect</h2>
        <p>
          When you contact us through our website's contact form, we collect the information
          you voluntarily provide:
        </p>
        <ul>
          <li>Your name and email address</li>
          <li>Your WhatsApp / phone number (if provided)</li>
          <li>Your preferred check-in and check-out dates and number of guests</li>
          <li>How you heard about us (if provided)</li>
          <li>Your message or enquiry</li>
        </ul>
        <p>
          We use this information solely to respond to your enquiry and assist with your
          booking. We do not collect data through automated means (such as analytics or
          advertising trackers) on this website at this time.
        </p>

        <h2>2. How We Use Your Data</h2>
        <ul>
          <li>To respond to your enquiries and booking requests</li>
          <li>To provide information about our rooms, wellness facilities, and services</li>
          <li>To communicate with you about your stay, if you proceed with a booking</li>
        </ul>
        <p>
          We do not sell, rent, or share your personal data with third parties for marketing
          purposes. Your data is only shared with service providers who help us operate our
          business (such as our booking engine provider) when necessary to process your
          reservation.
        </p>

        <h2>3. Booking Engine</h2>
        <p>
          When you click "Book Direct &amp; Save", you are redirected to our third-party
          booking engine (SiteMinder DirectOnline). Any data you enter on that platform is
          governed by their own privacy policy. We encourage you to review their terms before
          submitting personal or payment information.
        </p>

        <h2>4. Third-Party Embeds</h2>
        <p>
          Our website embeds content from third-party platforms:
        </p>
        <ul>
          <li><strong>TikTok</strong> — video embeds from our official account may set cookies or collect data when you interact with them.</li>
          <li><strong>Google Maps</strong> — embedded map widgets may collect usage data.</li>
          <li><strong>WhatsApp</strong> — clicking our WhatsApp links opens WhatsApp's platform, which is subject to their privacy policy.</li>
        </ul>
        <p>
          We do not control the data practices of these third parties. Please review their
          respective privacy policies for more information.
        </p>

        <h2>5. Cookies</h2>
        <p>
          Our website does not set its own tracking or advertising cookies. We do not use
          Google Analytics or similar analytics services at this time. Third-party embeds
          (listed above) may set their own cookies when you interact with them.
        </p>

        <h2>6. Data Retention</h2>
        <p>
          We retain personal data from enquiries only for as long as necessary to respond to
          your request and, if applicable, to provide services related to your stay. You may
          request deletion of your data at any time (see section 8).
        </p>

        <h2>7. Your Rights</h2>
        <p>Depending on your location, you may have the right to:</p>
        <ul>
          <li>Access the personal data we hold about you</li>
          <li>Request correction of inaccurate data</li>
          <li>Request deletion of your data</li>
          <li>Withdraw consent to processing at any time</li>
          <li>Lodge a complaint with your local data protection authority</li>
        </ul>

        <h2>8. Contacting Us About Privacy</h2>
        <p>
          If you have any questions about this Privacy Policy or wish to exercise your data
          protection rights, please contact us:
        </p>
        <ul>
          <li>Email: <a href={`mailto:${contact.email}`}>{contact.email}</a></li>
          <li>WhatsApp: <a href={contact.whatsappLink} target="_blank" rel="noopener">{contact.whatsapp}</a></li>
        </ul>

        <h2>9. Changes to This Policy</h2>
        <p>
          We may update this Privacy Policy from time to time. Changes will be posted on this
          page with an updated revision date. We encourage you to review this page
          periodically.
        </p>
      </div>

      <div class="mt-12 border-t border-line pt-6">
        <a href="/" class="btn-ghost">← Back to home</a>
      </div>
    </div>
  </section>
</Base>

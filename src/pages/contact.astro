---
/**
 * Contact page — /contact
 * Brief (client, 2026-06-20): simple, clear, conversion-focused.
 * Boutique feel — warm, helpful, premium. Form is the main focus.
 *
 * Flow: Hero → Contact Form + Direct Contact (WhatsApp/email) →
 * Book Directly → Location reminder → Response time → Social
 *
 * Form: posts to a /thank-you placeholder for now (no backend yet).
 * TODO: wire to form handler (Netlify Forms / Formspree / email service)
 *       or convert submit to a WhatsApp deep-link for zero-backend MVP.
 */
import Base from '@layouts/Base.astro';
import { site, contact, booking } from '@data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${site.url}/contact` },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: site.name,
  description: site.description,
  url: `${site.url}/contact`,
  telephone: contact.whatsapp,
  email: contact.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.addressLine1,
    addressLocality: 'Nusa Ceningan',
    addressRegion: 'Bali',
    addressCountry: 'ID',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -8.6968955,
    longitude: 115.4498182,
  },
};
---

<Base
  title="Contact | Segara Seaside Resort, Nusa Ceningan"
  description="Get in touch with Segara Seaside Resort. Send a message, chat on WhatsApp, or book directly for the best rates. We reply within a few hours."
  image="/images/general/pool-bar.jpg"
  schema={[localBusinessSchema, breadcrumbSchema]}
>
  {/* ─── HERO ─── */}
  <section class="bg-lagoon-700 py-20 text-center text-white md:py-28">
    <div class="container-content">
      <p class="overline text-white/70">Contact</p>
      <h1 class="mt-3 text-[clamp(2.25rem,5vw,3.5rem)] text-white">Get in Touch</h1>
      <p class="mx-auto mt-5 max-w-xl text-white/85">
        We’d love to help you plan your stay at Segara Seaside Resort near Nusa Lembongan.
      </p>
    </div>
  </section>

  {/* ─── FORM + DIRECT CONTACT ─── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
        {/* Contact form (main focus) */}
        <div>
          <h2 class="text-2xl">Send Us a Message</h2>
          <p class="mt-2 text-sm text-slate">
            Tell us about your trip and we’ll get back to you with availability and the best rates.
          </p>

          <form
            name="contact"
            method="POST"
            action="/thank-you"
            class="mt-8 space-y-5"
          >
            {/* Honeypot for spam (Netlify-style) */}
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don’t fill this out: <input name="bot-field" /></label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Full Name *</span>
                <input
                  type="text"
                  name="name"
                  required
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                  placeholder="Your name"
                />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Email *</span>
                <input
                  type="email"
                  name="email"
                  required
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                  placeholder="you@email.com"
                />
              </label>
            </div>

            <label class="block">
              <span class="text-xs uppercase tracking-wide text-slate">WhatsApp Number</span>
              <input
                type="tel"
                name="whatsapp"
                class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                placeholder="+62 ..."
              />
            </label>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Check-in</span>
                <input
                  type="date"
                  name="checkin"
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Check-out</span>
                <input
                  type="date"
                  name="checkout"
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Guests</span>
                <select
                  name="guests"
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                >
                  <option>1 Guest</option>
                  <option selected>2 Guests</option>
                  <option>3 Guests</option>
                  <option>4 Guests</option>
                  <option>5+ Guests</option>
                </select>
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">How did you hear about us?</span>
                <select
                  name="referral"
                  class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                >
                  <option value="">Select…</option>
                  <option>Google search</option>
                  <option>Instagram</option>
                  <option>Booking.com / Expedia</option>
                  <option>Friend / recommendation</option>
                  <option>TikTok</option>
                  <option>Other</option>
                </select>
              </label>
            </div>

            <label class="block">
              <span class="text-xs uppercase tracking-wide text-slate">Message *</span>
              <textarea
                name="message"
                rows="4"
                required
                class="mt-1 w-full rounded border border-line bg-mist px-4 py-2.5 text-sm focus:border-lagoon-600 focus:bg-paper"
                placeholder="Tell us about your trip, any special requests (pet-friendly, honeymoon, etc.)…"
              ></textarea>
            </label>

            <button type="submit" class="btn-primary w-full text-base sm:w-auto">
              Request Booking Information ▸
            </button>
          </form>
        </div>

        {/* Direct contact sidebar */}
        <aside class="lg:sticky lg:top-24 lg:self-start">
          {/* WhatsApp — prominent */}
          <div class="rounded-lg border border-line bg-seafoam-100 p-6">
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-lagoon-600 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.8.8.8-2.7-.2-.3A8 8 0 0 1 12 4z"/><path d="M8.5 8c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.1s.9 2.4 1 2.6c.1.2 1.8 2.9 4.5 3.9 2.2.9 2.7.7 3.2.7.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.6-.3l-1.9-.9c-.3-.1-.5-.1-.7.1l-.7.9c-.1.2-.3.2-.5.1-.7-.3-1.4-.6-2.1-1.4-.5-.5-.9-1.1-1-1.3-.1-.2 0-.4.1-.5l.5-.6c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.9-2.1c-.2-.5-.4-.5-.6-.5z"/></svg>
              </span>
              <div>
                <h3 class="font-serif text-lg text-ink">Chat on WhatsApp</h3>
                <p class="text-xs text-slate">The fastest way to reach us</p>
              </div>
            </div>
            <a href={contact.whatsappLink} class="btn-primary mt-4 w-full" target="_blank" rel="noopener">
              {contact.whatsapp}
            </a>
          </div>

          {/* Email + phone */}
          <div class="mt-6 space-y-4">
            <div class="rounded-lg border border-line bg-mist p-5">
              <h3 class="text-xs uppercase tracking-wide text-slate">Email</h3>
              <a href={`mailto:${contact.email}`} class="mt-1 block text-sm text-lagoon-600 hover:underline">
                {contact.email}
              </a>
            </div>
            <div class="rounded-lg border border-line bg-mist p-5">
              <h3 class="text-xs uppercase tracking-wide text-slate">Phone / WhatsApp</h3>
              <p class="mt-1 text-sm text-ink/80">{contact.whatsapp}</p>
            </div>
          </div>

          {/* Response time */}
          <div class="mt-6 rounded-lg bg-lagoon-700 p-5 text-white">
            <h3 class="text-xs uppercase tracking-wide text-white/70">Response Time</h3>
            <p class="mt-2 text-sm text-white/90">
              We usually reply within a few hours during the day. For urgent requests, please message
              us on WhatsApp.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ─── BOOK DIRECTLY ─── */}
  <section class="bg-seafoam-100 py-16">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <p class="overline">Direct Bookings</p>
        <h2 class="mt-3 text-[clamp(1.75rem,3vw,2.5rem)]">Prefer to Book Directly?</h2>
        <p class="mt-4 text-slate">
          Booking directly with us comes with real benefits — and direct communication is especially
          useful for special requests like pet-friendly stays.
        </p>
      </div>
      <ul class="mx-auto mt-8 grid max-w-3xl gap-4 sm:grid-cols-2">
        {booking.perks.map((perk) => (
          <li class="flex items-start gap-3 rounded-lg border border-line bg-paper p-4">
            <span class="mt-0.5 flex h-6 w-6 flex-none items-center justify-center rounded-full bg-lagoon-600 text-xs text-white">✓</span>
            <span class="text-sm text-ink/80">{perk}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8 text-center">
        <a href={booking.bookingUrl} class="btn-primary">Book Direct &amp; Save ▸</a>
      </div>
    </div>
  </section>

  {/* ─── LOCATION REMINDER ─── */}
  <section class="section bg-paper">
    <div class="container-content">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="overline">Find Us</p>
          <h2 class="mt-3 text-2xl">Segara Seaside Resort</h2>
          <address class="mt-4 not-italic leading-relaxed text-slate">
            {contact.addressLine1}<br />
            {contact.addressLine2}
          </address>
          <p class="mt-4 text-sm text-slate">
            Just minutes from the Yellow Bridge and everything Nusa Lembongan has to offer.
          </p>
          <a href="/location" class="btn-ghost mt-4 text-sm">View full location guide ▸</a>
        </div>
        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200">
          <iframe
            title="Segara Seaside Resort location map"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7774.909644143069!2d115.44981820000001!3d-8.6968955!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd26da731527811%3A0x639e2fe202921059!2sSegara%20Seaside%20Resort!5e1!3m2!1sde!2s!4v1781894673297!5m2!1sde!2s"
            class="h-full w-full"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  {/* ─── SOCIAL ─── */}
  <section class="bg-lagoon-700 py-12 text-center text-white">
    <div class="container-content">
      <p class="overline text-white/70">Follow Our Journey</p>
      <h2 class="mt-2 font-serif text-xl text-white">{contact.instagram}</h2>
      <a href={contact.instagramUrl} class="btn-secondary mt-4 border-white/70 text-white hover:bg-white/10" target="_blank" rel="noopener">
        Follow on Instagram ▸
      </a>
    </div>
  </section>
</Base>

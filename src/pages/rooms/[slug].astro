---
/**
 * Room detail page — dynamic route /rooms/[slug].
 * Template applies to all 3 rooms (villa + 2 bungalows).
 * Per docs/05-wireframes.md §3 (Room Detail Page).
 *
 * Booking: SiteMinder DirectOnline engine. The sticky booking-card date +
 * guest pickers assemble a live booking URL client-side (data-booking-card
 * script at the bottom), deep-linked to this room when room.rateId is set.
 * See booking config + buildBookingUrl() in src/data/site.ts.
 */
import Base from '@layouts/Base.astro';
import { rooms, site, contact, booking, buildBookingUrl } from '@data/site';

// Static prerender of all rooms → /rooms/sunset-villa, /rooms/ocean-bungalow, /rooms/bungalow
export function getStaticPaths() {
  return rooms.map((room) => ({ params: { slug: room.slug }, props: { room } }));
}

const { room } = Astro.props;

// Static fallback URL rendered into the HTML for no-JS clients.
// When JS runs, the script below overrides this with the guest's dates/guests.
const fallbackBookingUrl = buildBookingUrl({ rateId: room.rateId });

// Split long description into paragraphs (separated by \n\n in data)
const descriptionParagraphs = room.longDescription.split('\n').filter(Boolean);

// Cross-sell: the other rooms
const otherRooms = rooms.filter((r) => r.slug !== room.slug);

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Rooms', item: `${site.url}/rooms` },
    { '@type': 'ListItem', position: 3, name: room.name, item: `${site.url}${room.href}` },
  ],
};

// LodgingBusiness / Room schema for SEO — includes price offer + occupancy
const roomSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: `${site.name} — ${room.name}`,
  description: room.longDescription,
  url: `${site.url}${room.href}`,
  image: `${site.url}${room.image}`,
  starRating: { '@type': 'Rating', ratingValue: '3' },
  priceRange: '$$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.4',
    reviewCount: '100',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Nusa Ceningan',
    addressRegion: 'Bali',
    addressCountry: 'ID',
  },
  amenityFeature: room.amenityGroups
    .flatMap((g) => g.items)
    .map((a) => ({
      '@type': 'LocationFeatureSpecification',
      name: a,
    })),
  // Price + occupancy offer
  makesOffer: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: room.priceFromIDR,
      priceCurrency: 'IDR',
      referenceQuantity: { '@type': 'QuantitativeValue', value: 1, unitCode: 'DAY' },
    },
  },
  occupancy: {
    '@type': 'QuantitativeValue',
    maxValue: room.specs.sleeps,
  },
};
---

<Base
  title={room.metaTitle}
  description={room.metaDescription}
  image={room.image}
  schema={[roomSchema, breadcrumbSchema]}
>
  {/* ─── BREADCRUMB ─── */}
  <div class="border-b border-line bg-mist">
    <div class="container-content py-4">
      <nav class="text-sm text-slate" aria-label="Breadcrumb">
        <a href="/" class="hover:text-lagoon-600">Home</a>
        <span class="mx-2">›</span>
        <a href="/rooms" class="hover:text-lagoon-600">Rooms</a>
        <span class="mx-2">›</span>
        <span class="text-ink">{room.name}</span>
      </nav>
    </div>
  </div>

  {/* ─── GALLERY ─── */}
  <section class="bg-paper pt-10">
    <div class="container-content">
      <div class="grid gap-3 lg:grid-cols-[2fr_1fr]">
        <div class="aspect-[4/3] overflow-hidden rounded-lg bg-seafoam-200 lg:aspect-[16/10]">
          <img
            src={room.gallery[0]}
            alt={`${room.name} at ${site.name}`}
            class="h-full w-full object-cover"
          />
        </div>
        <div class="grid grid-cols-3 gap-3 lg:grid-cols-1">
          {room.gallery.slice(1).map((img) => (
            <div class="aspect-square overflow-hidden rounded-lg bg-seafoam-200 lg:aspect-[4/3]">
              <img
                src={img}
                alt={`${room.name} detail`}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ─── HEADER + STICKY BOOKING CARD ─── */}
  <section class="bg-paper py-12">
    <div class="container-content">
      <div class="grid gap-12 lg:grid-cols-[1.6fr_1fr]">
        {/* Left: content */}
        <div>
          <p class="overline">{room.overline}</p>
          <h1 class="mt-3 text-[clamp(2rem,4vw,3rem)]">{room.name}</h1>

          {/* Quick specs */}
          <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate">
            <span>📐 {room.specs.size}</span>
            <span>🛏️ {room.specs.beds}</span>
            <span>👥 Sleeps {room.specs.sleeps}</span>
            <span>🌊 {room.specs.view}</span>
          </div>

          <p class="mt-8 max-w-prose text-lg leading-relaxed text-ink/90">
            {descriptionParagraphs.map((para) => (
              <span class="mt-4 block">{para}</span>
            ))}
          </p>

          {/* Perfect For */}
          <h2 class="mt-12 text-2xl">Perfect For</h2>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {room.perfectFor.map((p) => (
              <li class="flex items-start gap-2 text-sm text-ink/80">
                <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-seafoam-100 text-lagoon-600">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6l3 3 5-6" /></svg>
                </span>
                {p}
              </li>
            ))}
          </ul>

          {/* Amenities — categorized */}
          <h2 class="mt-12 text-2xl">Room Amenities</h2>
          <div class="mt-6 grid gap-8 sm:grid-cols-2">
            {room.amenityGroups.map((group) => (
              <div>
                <h3 class="overline">{group.category}</h3>
                <ul class="mt-3 space-y-2">
                  {group.items.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-ink/80">
                      <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-seafoam-100 text-lagoon-600">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6l3 3 5-6" /></svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          {/* Location benefit (SEO + helpful) */}
          <div class="mt-12 rounded-lg border border-line bg-seafoam-100 p-6">
            <h3 class="font-serif text-lg text-ink">Location Benefits</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate">{room.locationBenefit}</p>
          </div>
        </div>

        {/* Right: sticky booking card */}
        <aside class="lg:sticky lg:top-24 lg:self-start">
          <div class="rounded-lg border border-line bg-mist p-6 shadow-sm" data-booking-card>
            <p class="text-sm text-slate">From</p>
            <p class="font-serif text-3xl text-brass-600">{room.priceFromLabel}</p>
            <p class="text-sm text-slate">per night · taxes included</p>

            {/* Date / guest selectors — drive the booking URL client-side.
                 The script at the bottom reads these and rebuilds the
                 "Book" button href whenever they change. */}
            <div class="mt-6 space-y-3">
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Check-in</span>
                <input
                  type="date"
                  name="checkIn"
                  data-booking-checkin
                  class="mt-1 w-full rounded border border-line bg-paper px-3 py-2 text-sm"
                />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Check-out</span>
                <input
                  type="date"
                  name="checkOut"
                  data-booking-checkout
                  class="mt-1 w-full rounded border border-line bg-paper px-3 py-2 text-sm"
                />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wide text-slate">Guests</span>
                <select
                  name="adults"
                  data-booking-adults
                  class="mt-1 w-full rounded border border-line bg-paper px-3 py-2 text-sm"
                >
                  <option value="1">1 Guest</option>
                  <option value="2" selected>2 Guests</option>
                  {room.specs.sleeps > 2 && <option value="3">3 Guests</option>}
                  {room.specs.sleeps > 3 && <option value="4">4 Guests</option>}
                </select>
              </label>
            </div>

            <a
              href={fallbackBookingUrl}
              class="btn-primary mt-6 w-full text-base"
              data-booking-link
              target="_blank"
              rel="noopener"
            >
              Book Direct & Save ▸
            </a>

            <ul class="mt-5 space-y-2 text-xs text-slate">
              {booking.perks.map((perk) => (
                <li class="flex items-center gap-2">
                  <span class="text-lagoon-600">✓</span> {perk}
                </li>
              ))}
            </ul>

            <div class="mt-6 border-t border-line pt-4 text-center">
              <p class="text-xs text-slate">Questions?</p>
              <a href={contact.whatsappLink} class="mt-1 inline-flex items-center gap-1.5 text-sm text-lagoon-600 hover:underline" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.8.8.8-2.7-.2-.3A8 8 0 0 1 12 4z"/></svg>
                Chat on WhatsApp
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ─── FINAL CTA ─── */}
  <section class="bg-lagoon-700 py-16 text-center text-white md:py-20">
    <div class="container-content">
      <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] text-white">{room.ctaText}</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/85">
        Book this {room.name.toLowerCase()} directly and enjoy our best rates with personal service from our team.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={fallbackBookingUrl} class="btn-primary text-base" data-booking-link-cta target="_blank" rel="noopener">
          Book Your Stay Now ▸
        </a>
        <a href={contact.whatsappLink} class="btn-secondary border-white/70 text-white hover:bg-white/10" target="_blank" rel="noopener">
          Ask on WhatsApp
        </a>
      </div>
    </div>
  </section>

  {/* ─── OTHER ROOMS (cross-sell) ─── */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="max-w-2xl">
        <p class="overline">Explore More</p>
        <h2 class="mt-3 text-[clamp(1.75rem,3vw,2.5rem)]">Other Accommodations</h2>
      </div>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {otherRooms.map((r) => (
          <a href={r.href} class="card group">
            <div class="aspect-[4/3] overflow-hidden bg-seafoam-200">
              <img
                src={r.image}
                alt={r.name}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <p class="overline">{r.overline}</p>
              <h3 class="mt-2 text-xl">{r.name}</h3>
              <p class="mt-2 text-sm text-slate line-clamp-2">{r.shortDescription}</p>
              <p class="mt-4 text-sm text-slate">
                From <span class="font-medium text-brass-600">{r.priceFromLabel}</span> / night
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<script is:inline define:vars={{ bookingConfig: { baseUrl: booking.baseUrl, locale: booking.locale, currency: booking.currency }, rateId: room.rateId }}>
  // Assemble the SiteMinder DirectOnline booking URL from the guest's
  // selections and update every [data-booking-link] on the page.
  // Mirrors buildBookingUrl() in src/data/site.ts.
  (function () {
    const card = document.querySelector('[data-booking-card]');
    if (!card) return;

    const checkin = card.querySelector('[data-booking-checkin]');
    const checkout = card.querySelector('[data-booking-checkout]');
    const adultsSel = card.querySelector('[data-booking-adults]');
    const links = document.querySelectorAll('[data-booking-link], [data-booking-link-cta]');
    if (!checkin || !checkout || !adultsSel || !links.length) return;

    // today / tomorrow / day-after as YYYY-MM-DD, local time.
    const iso = (d) => d.toISOString().slice(0, 10);
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const tomorrow = new Date(today); tomorrow.setDate(tomorrow.getDate() + 1);
    const dayAfter = new Date(today); dayAfter.setDate(dayAfter.getDate() + 2);

    checkin.min = iso(today);
    checkin.value = iso(tomorrow);
    checkout.min = iso(dayAfter);
    checkout.value = iso(dayAfter);

    const buildUrl = () => {
      const params = new URLSearchParams();
      params.set('locale', bookingConfig.locale);
      params.set('currency', bookingConfig.currency);
      params.set('items[0][adults]', adultsSel.value || '2');
      params.set('items[0][children]', '0');
      params.set('items[0][infants]', '0');
      if (rateId) params.set('items[0][rateId]', rateId);
      if (checkin.value) params.set('checkInDate', checkin.value);
      if (checkout.value) params.set('checkOutDate', checkout.value);
      params.set('trackPage', 'no');
      params.set('selected', '0');
      return `${bookingConfig.baseUrl}?${params.toString()}`;
    };

    const sync = () => {
      // Keep checkout at least one night ahead of check-in.
      if (checkin.value) {
        const ci = new Date(checkin.value + 'T00:00:00');
        const minOut = new Date(ci); minOut.setDate(minOut.getDate() + 1);
        checkout.min = iso(minOut);
        if (checkout.value && new Date(checkout.value + 'T00:00:00') <= ci) {
          checkout.value = iso(minOut);
        }
      }
      const url = buildUrl();
      links.forEach((a) => { a.setAttribute('href', url); });
    };

    [checkin, checkout, adultsSel].forEach((el) => el.addEventListener('change', sync));
    sync();
  })();
</script>

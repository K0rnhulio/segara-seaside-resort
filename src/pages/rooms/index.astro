---
/**
 * Rooms overview page — /rooms
 * Lists all accommodations with quick facts + links to detail pages.
 * Per docs/02-sitemap.md.
 */
import Base from '@layouts/Base.astro';
import { rooms, site, reviews } from '@data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Rooms', item: `${site.url}/rooms` },
  ],
};

// ItemList schema — tells search engines this page lists our rooms
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Rooms & Villas at Segara Seaside Resort',
  itemListElement: rooms.map((room, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: room.name,
    url: `${site.url}${room.href}`,
  })),
};

// LodgingBusiness schema for the resort (room offer context)
const roomsLodgingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: site.name,
  description:
    'Choose from elegant Deluxe Bungalows with sea views or our spacious Two-Bedroom Villa with Private Pool. Boutique oceanfront accommodation on Nusa Ceningan, near Nusa Lembongan.',
  url: `${site.url}/rooms`,
  image: `${site.url}/images/rooms/two-bedroom-villa.jpg`,
  starRating: { '@type': 'Rating', ratingValue: '3' },
  priceRange: '$$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: String(reviews.googleRating),
    reviewCount: String(reviews.googleCount),
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Nusa Ceningan',
    addressRegion: 'Bali',
    addressCountry: 'ID',
  },
};
---

<Base
  title="Rooms & Villas | Segara Seaside Resort Nusa Ceningan"
  description="Deluxe Bungalows with sea views and a Two-Bedroom Villa with private pool. Boutique oceanfront accommodation on Nusa Ceningan, near Nusa Lembongan."
  image="/images/rooms/two-bedroom-villa.jpg"
  schema={[breadcrumbSchema, itemListSchema, roomsLodgingSchema]}
>
  {/* Hero */}
  <section class="bg-lagoon-700 py-20 text-white md:py-28">
    <div class="container-content text-center">
      <p class="overline text-white/70">Accommodation</p>
      <h1 class="mt-3 text-[clamp(2.25rem,4vw,3.5rem)] text-white">
        Thoughtfully Designed Stays
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-white/85">
        Choose from elegant Deluxe Bungalows or our spacious Two-Bedroom Villa with Private Pool.
        All accommodations are designed for comfort and feature modern amenities in a serene island setting.
      </p>
    </div>
  </section>

  {/* Rooms grid */}
  <section class="section bg-mist">
    <div class="container-content">
      <div class="grid gap-8 lg:grid-cols-3">
        {rooms.map((room) => (
          <article class="card group flex flex-col">
            <a href={room.href} class="block aspect-[4/3] overflow-hidden bg-seafoam-200">
              <img
                src={room.image}
                alt={`${room.name} at ${site.name}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </a>
            <div class="flex flex-1 flex-col p-6">
              <p class="overline">{room.overline}</p>
              <h2 class="mt-2 text-xl">
                <a href={room.href} class="hover:text-lagoon-600">{room.name}</a>
              </h2>

              {/* Quick specs */}
              <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate">
                <span>📐 {room.specs.size}</span>
                <span>👥 Sleeps {room.specs.sleeps}</span>
                <span>🌊 {room.specs.view}</span>
              </div>

              <p class="mt-4 flex-1 text-sm leading-relaxed text-slate">{room.shortDescription}</p>

              {/* Feature chips */}
              <ul class="mt-4 flex flex-wrap gap-2">
                {room.features.map((f) => (
                  <li class="rounded-full bg-seafoam-100 px-3 py-1 text-xs text-lagoon-700">{f}</li>
                ))}
              </ul>

              <div class="mt-6 flex items-center justify-between border-t border-line pt-4">
                <p class="text-sm text-slate">
                  From <span class="font-medium text-brass-600 text-base">{room.priceFromLabel}</span>
                  <span class="text-xs"> / night</span>
                </p>
                <a href={room.href} class="btn-ghost text-sm">View ▸</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

---
/**
 * FAQ section — SEO-heavy Q&A with accessible accordion (native <details>,
 * zero JS) and FAQPage JSON-LD schema injection via the page.
 * Content + schema source: src/data/site.ts → faqs
 * See docs/01-keyword-research.md §5.8 (FAQPage schema).
 */
import { faqs } from '@data/site';
---

<section class="section bg-mist" id="faq" aria-labelledby="faq-heading">
  <div class="container-content">
    <div class="mx-auto max-w-2xl text-center">
      <p class="overline">Good to Know</p>
      <h2 id="faq-heading" class="mt-3 text-[clamp(2rem,3.5vw,3rem)]">
        Frequently Asked Questions
      </h2>
      <p class="mt-4 text-slate">
        Everything you need to plan your escape to Nusa Ceningan — from getting
        here to the best time to visit.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-3xl divide-y divide-line">
      {
        faqs.map((item, i) => (
          <details class="group py-5" name="faq" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-serif text-lg text-ink marker:hidden [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <span
                class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full border border-line text-lagoon-600 transition-transform duration-300 group-open:rotate-45"
                aria-hidden="true"
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="7" y1="1" x2="7" y2="13" />
                  <line x1="1" y1="7" x2="13" y2="7" />
                </svg>
              </span>
            </summary>
            <p class="mt-4 max-w-prose leading-relaxed text-slate">{item.answer}</p>
          </details>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-2xl text-center">
      <p class="text-sm text-slate">Still have a question?</p>
      <a href="/contact" class="btn-ghost mt-2">Get in touch ▸</a>
    </div>
  </div>
</section>

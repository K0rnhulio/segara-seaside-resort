---
/**
 * Site footer — brand block · explore · contact · social.
 * Newsletter intentionally omitted (replaced by Instagram feed on home).
 * See wireframes footer + sitemap §4.
 */
import { site, contact, nav, cta } from '@data/site';

const year = new Date().getFullYear();
---

<footer class="bg-lagoon-700 text-white">
  <div class="container-content py-16">
    <div class="grid gap-12 md:grid-cols-3">
      {/* Brand */}
      <div>
        <a href="/" class="inline-block hover:opacity-80" aria-label={`${site.name} — home`}>
          <img src="/images/segara-logo.png" alt={`${site.name} logo`} class="h-12 w-auto brightness-0 invert" width="180" height="48" />
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-white/75">
          {site.tagline}. Beachfront villas, cozy bungalows & unforgettable sunsets.
        </p>
        <div class="mt-6 flex gap-4">
          <a href={contact.instagramUrl} aria-label="Instagram" class="text-white/80 hover:text-white" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
            </svg>
          </a>
          <a href={contact.facebook} aria-label="Facebook" class="text-white/80 hover:text-white" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14 9h3l.5-3H14V4.5c0-.9.3-1.5 1.7-1.5H17V.2C16.6.1 15.5 0 14.3 0 11.8 0 10 1.5 10 4.3V6H7v3h3v9h4V9z" />
            </svg>
          </a>
          <a href={contact.tiktok} aria-label="TikTok" class="text-white/80 hover:text-white" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 3c.3 2.3 1.7 4 4 4.3v3c-1.5 0-2.9-.5-4-1.3v6.5c0 3.3-2.7 6-6 6s-6-2.7-6-6 2.7-6 6-6c.3 0 .7 0 1 .1v3.2c-.3-.1-.6-.2-1-.2-1.6 0-2.9 1.3-2.9 2.9s1.3 2.9 2.9 2.9 2.9-1.3 2.9-2.9V3H16z" />
            </svg>
          </a>
        </div>
      </div>

      {/* Explore */}
      <div>
        <h3 class="overline text-white/60">Explore</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="text-white/80 hover:text-white">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h3 class="overline text-white/60">Contact</h3>
        <address class="mt-4 space-y-2 text-sm not-italic text-white/80">
          <p>{contact.addressLine1}<br />{contact.addressLine2}</p>
          <p>
            <a href={contact.whatsappLink} class="hover:text-white" target="_blank" rel="noopener">
              WhatsApp {contact.whatsapp}
            </a>
          </p>
          <p>
            <a href={`mailto:${contact.email}`} class="hover:text-white">{contact.email}</a>
          </p>
          <p>
            <a href={contact.instagramUrl} class="hover:text-white" target="_blank" rel="noopener">
              Follow {contact.instagram}
            </a>
          </p>
        </address>
        <a href="/rooms" class="btn-primary mt-6">{cta.label}</a>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/15 pt-6 text-xs text-white/60 sm:flex-row">
      <p>© {year} {site.name}. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/terms" class="hover:text-white">Terms</a>
        <a href="/imprint" class="hover:text-white">Imprint</a>
      </div>
    </div>
  </div>
</footer>
